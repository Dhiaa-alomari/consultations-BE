                "exec": [
                  "const res = pm.response.json();",
                  "if (res.tokens) {",
                  "  pm.collectionVariables.set('access_token', res.tokens.access);",
                  "  pm.collectionVariables.set('refresh_token', res.tokens.refresh);",
                  "  console.log('✅ Tokens saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
